# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# LangChain/LangGraph reads these automatically — no explicit os.environ calls needed.
# Set LANGCHAIN_TRACING_V2=true to enable trace logging in LangSmith.
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=india-finance-deep-researcher
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default, override if self-hosting

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8001

# ── LLM Models ────────────────────────────────────────────────────────────────
# Planner: decomposes the research question into sub-questions (high reasoning)
PLANNER_MODEL=o3

# Evaluator: decides when enough notes have been gathered to write the report
EVALUATOR_MODEL=gpt-4o

# Agent loop model: decides which tool to call next (hardcoded in graph.py)
# AGENT_MODEL=gpt-4o

# Synthesizer: writes the final structured report (hardcoded in synthesize.py)
# SYNTHESIZER_MODEL=gpt-4o

# ── Connector network settings ────────────────────────────────────────────────
# Request timeout in seconds for all connector HTTP calls
CONNECTOR_TIMEOUT=30

# Max retry attempts on 429 / 5xx responses (exponential backoff: 2s, 4s, 8s, 16s...)
CONNECTOR_RETRIES=5

# ── Data source base URLs ─────────────────────────────────────────────────────
# Override if endpoints change or you need to route through a proxy

# RBI macro data + IMF GDP outlook — World Bank API (used by both rbi.py and imf.py)
WORLDBANK_API_BASE=https://api.worldbank.org/v2/country/IN/indicator

# SEBI insider trading — NSE PIT disclosure API
NSE_BASE_URL=https://www.nseindia.com

# BSE ticker resolution — Yahoo Finance search API
YAHOO_SEARCH_URL=https://query2.finance.yahoo.com/v1/finance/search
